<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screenshots.Views.ImageEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editor="using:helvety.screenshots.Editor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Height="146"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="10">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border
                    Grid.Row="0"
                    Padding="0,0,0,6"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled"
                        ZoomMode="Disabled">
                        <StackPanel
                            x:Name="SharedPrimarySettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8">
                            <TextBlock Text="Color" VerticalAlignment="Center" />
                            <ComboBox
                                x:Name="PrimaryColorComboBox"
                                Width="128"
                                Height="34"
                                VerticalAlignment="Center"
                                SelectionChanged="PrimaryColorComboBox_SelectionChanged">
                                <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                <ComboBoxItem Content="Black" Tag="#FF000000" />
                                <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                            </ComboBox>
                            <Button
                                x:Name="PickPrimaryColorButton"
                                Content="Pick"
                                Height="34"
                                Click="PickPrimaryColorButton_Click" />
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <TextBlock Text="Thickness" VerticalAlignment="Center" />
                            <Slider
                                x:Name="PrimaryThicknessSlider"
                                Width="220"
                                Minimum="1"
                                Maximum="24"
                                StepFrequency="1"
                                TickFrequency="1"
                                Value="4"
                                ValueChanged="PrimaryThicknessSlider_ValueChanged" />
                            <TextBlock
                                x:Name="PrimaryThicknessValueText"
                                MinWidth="44"
                                VerticalAlignment="Center"
                                Text="4 px" />
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <ToggleSwitch
                                x:Name="SharedShadowToggle"
                                Header="Shadow"
                                VerticalAlignment="Center"
                                IsOn="True"
                                Toggled="ToolSettingToggled" />
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <TextBlock Text="Corner Radius" VerticalAlignment="Center" />
                            <Slider
                                x:Name="RegionCornerRadiusSlider"
                                Width="180"
                                Minimum="0"
                                Maximum="24"
                                StepFrequency="1"
                                TickFrequency="4"
                                Value="8"
                                ValueChanged="RegionCornerRadiusSlider_ValueChanged" />
                            <TextBlock
                                x:Name="RegionCornerRadiusValueText"
                                MinWidth="44"
                                VerticalAlignment="Center"
                                Text="8 px" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                <Border
                    Grid.Row="1"
                    Padding="0,6,0,0">
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled"
                        ZoomMode="Disabled">
                        <Grid>
                        <StackPanel
                            x:Name="MoveToolSettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8">
                            <TextBlock
                                x:Name="MoveSelectedTextLabel"
                                Text="Text"
                                VerticalAlignment="Center"
                                Visibility="Collapsed" />
                            <TextBox
                                x:Name="MoveSelectedTextTextBox"
                                Width="260"
                                Height="34"
                                PlaceholderText="Edit selected text"
                                TextChanged="MoveSelectedTextTextBox_TextChanged"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <StackPanel
                            x:Name="TextToolSettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <Button
                                x:Name="EditSelectedTextButton"
                                Height="34"
                                Click="EditSelectedTextButton_Click"
                                Content="Edit Selected Text"
                                Visibility="Collapsed" />
                            <TextBlock Text="Font" VerticalAlignment="Center" />
                            <ComboBox x:Name="TextFontComboBox" Width="150" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="Segoe UI" IsSelected="True" />
                                <ComboBoxItem Content="Arial" />
                                <ComboBoxItem Content="Calibri" />
                                <ComboBoxItem Content="Consolas" />
                            </ComboBox>
                            <TextBlock Text="Size" VerticalAlignment="Center" />
                            <NumberBox x:Name="TextSizeNumberBox" Width="84" Height="34" VerticalAlignment="Center" Minimum="8" Maximum="180" Value="38" ValueChanged="ToolSettingValueChanged" />
                            <TextBlock Text="Color" VerticalAlignment="Center" Visibility="Collapsed" />
                            <ComboBox x:Name="TextColorComboBox" Width="108" Height="34" VerticalAlignment="Center" Visibility="Collapsed" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                <ComboBoxItem Content="Black" Tag="#FF000000" />
                                <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                            </ComboBox>
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <ToggleSwitch x:Name="TextBorderToggle" Header="Border" VerticalAlignment="Center" IsOn="False" Toggled="ToolSettingToggled" />
                            <ComboBox x:Name="TextBorderColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="White" Tag="#FFFFFFFF" IsSelected="True" />
                                <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" />
                                <ComboBoxItem Content="Black" Tag="#FF000000" />
                                <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                <ComboBoxItem Content="Custom" Tag="#FFFFFFFF" />
                            </ComboBox>
                            <Button Content="Pick" Height="34" Click="PickTextBorderColorButton_Click" />
                            <NumberBox x:Name="TextBorderThicknessNumberBox" Width="72" Height="34" VerticalAlignment="Center" Minimum="1" Maximum="24" Value="1" Visibility="Collapsed" ValueChanged="ToolSettingValueChanged" />
                        </StackPanel>

                        <StackPanel
                            x:Name="BorderToolSettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock Text="Thickness" VerticalAlignment="Center" Visibility="Collapsed" />
                            <NumberBox x:Name="BorderThicknessNumberBox" Width="84" Height="34" VerticalAlignment="Center" Minimum="1" Maximum="24" Value="4" Visibility="Collapsed" ValueChanged="ToolSettingValueChanged" />
                            <TextBlock Text="Color" VerticalAlignment="Center" Visibility="Collapsed" />
                            <ComboBox x:Name="BorderColorComboBox" Width="108" Height="34" VerticalAlignment="Center" Visibility="Collapsed" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel
                            x:Name="BlurToolSettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock Text="Blur Radius" VerticalAlignment="Center" />
                            <NumberBox x:Name="BlurRadiusNumberBox" Width="84" Height="34" VerticalAlignment="Center" Minimum="1" Maximum="25" Value="6" ValueChanged="ToolSettingValueChanged" />
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <ToggleSwitch
                                x:Name="BlurInvertToggle"
                                Header="Blur Outside Selection"
                                VerticalAlignment="Center"
                                IsOn="False"
                                Toggled="BlurInvertToggle_Toggled" />
                        </StackPanel>

                        <StackPanel
                            x:Name="HighlightToolSettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock Text="Outside Dim" VerticalAlignment="Center" />
                            <Slider
                                x:Name="HighlightDimSlider"
                                Width="220"
                                Minimum="0"
                                Maximum="80"
                                StepFrequency="1"
                                TickFrequency="10"
                                ValueChanged="HighlightDimSlider_ValueChanged" />
                            <TextBlock
                                x:Name="HighlightDimValueText"
                                MinWidth="56"
                                VerticalAlignment="Center"
                                Text="35%" />
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <ToggleSwitch
                                x:Name="HighlightInvertToggle"
                                Header="Dim Selection Instead"
                                VerticalAlignment="Center"
                                IsOn="False"
                                Toggled="HighlightInvertToggle_Toggled" />
                        </StackPanel>

                        <StackPanel
                            x:Name="ArrowToolSettingsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="Collapsed">
                            <TextBlock Text="Thickness" VerticalAlignment="Center" Visibility="Collapsed" />
                            <NumberBox x:Name="ArrowThicknessNumberBox" Width="84" Height="34" VerticalAlignment="Center" Minimum="1" Maximum="24" Value="4" Visibility="Collapsed" ValueChanged="ToolSettingValueChanged" />
                            <TextBlock Text="Color" VerticalAlignment="Center" Visibility="Collapsed" />
                            <ComboBox x:Name="ArrowColorComboBox" Width="108" Height="34" VerticalAlignment="Center" Visibility="Collapsed" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                <ComboBoxItem Content="Black" Tag="#FF000000" />
                                <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                            </ComboBox>
                            <ToggleSwitch x:Name="ArrowBorderToggle" Header="Border" VerticalAlignment="Center" IsOn="False" Toggled="ToolSettingToggled" />
                            <ComboBox x:Name="ArrowBorderColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="Black" Tag="#FF000000" />
                                <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" />
                                <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                <ComboBoxItem Content="Custom" Tag="#FF000000" IsSelected="True" />
                            </ComboBox>
                            <Button Content="Pick" Height="34" Click="PickArrowBorderColorButton_Click" />
                            <NumberBox x:Name="ArrowBorderThicknessNumberBox" Width="72" Height="34" VerticalAlignment="Center" Minimum="1" Maximum="8" Value="1" ValueChanged="ToolSettingValueChanged" />
                            <Rectangle
                                Width="1"
                                Height="24"
                                VerticalAlignment="Center"
                                Fill="{ThemeResource CardStrokeColorDefaultBrush}" />
                            <TextBlock Text="Form" VerticalAlignment="Center" />
                            <ComboBox x:Name="ArrowFormComboBox" Width="120" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                <ComboBoxItem Content="Tapered" Tag="Tapered" IsSelected="True" />
                                <ComboBoxItem Content="Straight" Tag="Straight" />
                            </ComboBox>
                        </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="460" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Tools" />
                    <StackPanel Spacing="8">
                        <Button
                            x:Name="MoveToolButton"
                            Width="124"
                            Height="64"
                            Tag="Move"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE7C9;" />
                                <TextBlock FontSize="11" Text="Move" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="TextToolButton"
                            Width="124"
                            Height="64"
                            Tag="Text"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8D2;" />
                                <TextBlock FontSize="11" Text="Text" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="BorderToolButton"
                            Width="124"
                            Height="64"
                            Tag="Border"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Width="20" Height="20">
                                    <Grid Width="20" Height="20">
                                        <Rectangle
                                            Width="16"
                                            Height="12"
                                            RadiusX="2"
                                            RadiusY="2"
                                            Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                            StrokeThickness="1.8" />
                                        <Rectangle
                                            Width="12"
                                            Height="8"
                                            RadiusX="1"
                                            RadiusY="1"
                                            Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                            StrokeThickness="1.2"
                                            Opacity="0.65" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock FontSize="11" Text="Border" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="BlurToolButton"
                            Width="124"
                            Height="64"
                            Tag="Blur"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Width="20" Height="20">
                                    <Grid Width="20" Height="20">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="2,0,0,0"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                            Opacity="0.55" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,2,0"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                            Opacity="0.55" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock FontSize="11" Text="Blur" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="HighlightToolButton"
                            Width="124"
                            Height="64"
                            Tag="Highlight"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE790;" />
                                <TextBlock FontSize="11" Text="Highlight" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="ArrowToolButton"
                            Width="124"
                            Height="64"
                            Tag="Arrow"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Forward" />
                                <TextBlock FontSize="11" Text="Arrow" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="CropToolButton"
                            Width="124"
                            Height="64"
                            Tag="Crop"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE7A8;" />
                                <TextBlock FontSize="11" Text="Crop" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="6"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <ScrollViewer
                    x:Name="EditorScrollViewer"
                    HorizontalScrollBarVisibility="Visible"
                    VerticalScrollBarVisibility="Auto"
                    ZoomMode="Enabled">
                    <Grid
                        x:Name="EditorSurfaceGrid"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <Image
                            x:Name="BaseImage"
                            Stretch="None" />
                        <Canvas
                            x:Name="LayersCanvas"
                            IsHitTestVisible="False" />
                        <Canvas
                            x:Name="OverlayCanvas"
                            Background="Transparent"
                            DoubleTapped="OverlayCanvas_DoubleTapped"
                            PointerPressed="OverlayCanvas_PointerPressed"
                            PointerMoved="OverlayCanvas_PointerMoved"
                            PointerReleased="OverlayCanvas_PointerReleased" />
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border
                Grid.Column="2"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Layers" />
                    <ListView
                        Grid.Row="1"
                        x:Name="LayersListView"
                        SelectionMode="Single"
                        CanDragItems="True"
                        CanReorderItems="True"
                        AllowDrop="True"
                        HorizontalContentAlignment="Stretch"
                        DragItemsCompleted="LayersListView_DragItemsCompleted"
                        SelectionChanged="LayersListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="editor:EditorLayer">
                                <Border
                                    Padding="8,6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid ColumnSpacing="8" MinHeight="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid
                                            ColumnSpacing="8"
                                            VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton
                                                Grid.Column="0"
                                                IsChecked="{x:Bind IsVisible, Mode=TwoWay}"
                                                Checked="LayerVisibilityCheckBox_Changed"
                                                Unchecked="LayerVisibilityCheckBox_Changed"
                                                Tag="{x:Bind Id}">
                                                <SymbolIcon Symbol="View" />
                                            </ToggleButton>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Text="{x:Bind Name}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind LayerType}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                        <Button
                                            Grid.Column="1"
                                            Click="RemoveLayerButton_Click"
                                            Tag="{x:Bind Id}"
                                            ToolTipService.ToolTip="Delete layer">
                                            <SymbolIcon Symbol="Delete" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border
                        Grid.Row="2"
                        Padding="0,10,0,0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="8">
                            <TextBlock
                                HorizontalAlignment="Right"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="Export" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="SaveButton_Click" Content="Save As New File" />
                                <Button Click="OverrideButton_Click" Content="Override Existing File" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="CopyButton_Click" Content="Copy" />
                                <Button
                                    x:Name="SaveCropButton"
                                    Click="SaveCropButton_Click"
                                    Content="Save Crop"
                                    Visibility="Collapsed" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Page>
