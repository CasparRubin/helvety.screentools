<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="helvety.screenshots.Capture.SelectionOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Capture Selection">
    <Grid
        x:Name="RootGrid"
        Background="Transparent"
        KeyDown="RootGrid_KeyDown"
        PointerMoved="RootGrid_PointerMoved"
        PointerPressed="RootGrid_PointerPressed"
        PointerReleased="RootGrid_PointerReleased">
        <Image
            x:Name="BackgroundImage"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Stretch="None" />

        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Line
                x:Name="VerticalCursorGuide"
                Stroke="#8A8A8A"
                StrokeDashArray="2,6"
                StrokeThickness="1" />
            <Line
                x:Name="HorizontalCursorGuide"
                Stroke="#8A8A8A"
                StrokeDashArray="2,6"
                StrokeThickness="1" />
            <Rectangle
                x:Name="DimTop"
                Fill="#4D000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DimLeft"
                Fill="#4D000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DimRight"
                Fill="#4D000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DimBottom"
                Fill="#4D000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderRectangle"
                Stroke="Red"
                StrokeThickness="3"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DragRectangle"
                Fill="#22FF0000"
                Stroke="Red"
                StrokeThickness="2"
                Visibility="Collapsed" />
            <Border
                x:Name="InstructionPanel"
                MaxWidth="520"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Screenshot Mode" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Fast capture with snap and free selection."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Grid RowSpacing="8" ColumnSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Padding="8,3"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="LMB" />
                        </Border>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            TextWrapping="WrapWholeWords">
                            <Run FontWeight="SemiBold" Text="Left click" />
                            <Run Text=" saves, copies to clipboard, and exits mode." />
                        </TextBlock>

                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            Padding="8,3"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="RMB" />
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            TextWrapping="WrapWholeWords">
                            <Run FontWeight="SemiBold" Text="Right click" />
                            <Run Text=" saves and keeps frozen mode active." />
                        </TextBlock>

                        <Border
                            Grid.Row="2"
                            Grid.Column="0"
                            Padding="8,3"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="ESC" />
                        </Border>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            TextWrapping="WrapWholeWords">
                            <Run FontWeight="SemiBold" Text="Esc" />
                            <Run Text=" cancels screenshot mode." />
                        </TextBlock>
                    </Grid>

                    <Border
                        x:Name="InstructionStatusCard"
                        Padding="10"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="10">
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Latest status" />
                            <TextBlock
                                x:Name="InstructionStatusText"
                                FontWeight="SemiBold"
                                Text="Waiting for selection..."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="8,6"
                        Background="{ThemeResource ControlFillColorTertiaryBrush}"
                        CornerRadius="8">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="Note: This panel is never included in saved screenshots."
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
