<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="helvety.screentools.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:helvety.screentools">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <Color x:Key="HelvetyAccentColor">#FFD81B60</Color>
            <SolidColorBrush x:Key="HelvetyAccentBrush" Color="{StaticResource HelvetyAccentColor}" />
            <Color x:Key="HelvetyAccentSubtleColor">#30D81B60</Color>
            <SolidColorBrush x:Key="HelvetyAccentSubtleBrush" Color="{StaticResource HelvetyAccentSubtleColor}" />
            <Color x:Key="SystemAccentColor">#FFD81B60</Color>
            <Color x:Key="SystemAccentColorDark1">#FFC81658</Color>
            <Color x:Key="SystemAccentColorDark2">#FFB3144E</Color>
            <Color x:Key="SystemAccentColorDark3">#FF9E1145</Color>
            <Color x:Key="SystemAccentColorLight1">#FFE2497D</Color>
            <Color x:Key="SystemAccentColorLight2">#FFE95D8E</Color>
            <Color x:Key="SystemAccentColorLight3">#FFF07AA5</Color>
            <Style x:Key="SettingsCardBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="16" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>

            <Style x:Key="SettingsSectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="SettingsSectionDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="SettingsSubsectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="SettingsInlineRowStackPanelStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="Spacing" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsInlineLabelTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsInlineControlStyle" TargetType="Control">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsInlineButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsInlineControlStyle}">
                <Setter Property="Height" Value="34" />
            </Style>

            <Style x:Key="SettingsInlineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SettingsInlineControlStyle}">
                <Setter Property="Height" Value="34" />
            </Style>

            <Style x:Key="SettingsInlineComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource SettingsInlineControlStyle}">
                <Setter Property="Height" Value="34" />
            </Style>

            <Style x:Key="SettingsInlineNumberBoxStyle" TargetType="NumberBox" BasedOn="{StaticResource SettingsInlineControlStyle}">
                <Setter Property="Height" Value="34" />
            </Style>

            <Style x:Key="SettingsInlineSliderStyle" TargetType="Slider" BasedOn="{StaticResource SettingsInlineControlStyle}">
                <Setter Property="Height" Value="34" />
            </Style>

            <Style x:Key="SettingsInlineToggleSwitchStyle" TargetType="ToggleSwitch">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="34" />
            </Style>

            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
