<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.ScreenToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:helvety.screentools.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource AppPaddingPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="{StaticResource AppSpacingStack}">
            <TextBlock Style="{StaticResource AppPageTitleTextStyle}" Text="Screen Tools" />
            <TextBlock
                x:Name="SaveFolderPathText"
                Style="{StaticResource AppPageSubtitleTextStyle}" />
            <StackPanel
                x:Name="HotkeysHintPanel"
                Orientation="Horizontal"
                Spacing="{StaticResource AppSpacingStack}"
                VerticalAlignment="Center"
                Visibility="Collapsed">
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource AppPageSubtitleTextStyle}"
                    Text="Capture" />
                <controls:HotkeyChordStrip x:Name="CaptureHotkeyHintStrip" />
                <TextBlock
                    x:Name="LiveDrawHintSeparator"
                    VerticalAlignment="Center"
                    Style="{StaticResource AppPageSubtitleTextStyle}"
                    Text="·"
                    Visibility="Collapsed" />
                <TextBlock
                    x:Name="LiveDrawHintLabel"
                    VerticalAlignment="Center"
                    Style="{StaticResource AppPageSubtitleTextStyle}"
                    Text="Live Draw"
                    Visibility="Collapsed" />
                <controls:HotkeyChordStrip x:Name="LiveDrawHotkeyHintStrip" />
            </StackPanel>
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,16,0,0"
            Padding="{StaticResource AppPaddingCardLarge}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource AppCornerRadiusCard}">
            <Grid>
                <Border
                    x:Name="EmptyFolderCallout"
                    MaxWidth="700"
                    Padding="28"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppCornerRadiusCard}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <StackPanel Spacing="{StaticResource AppSpacingContent}">
                        <TextBlock Style="{StaticResource AppEmptyStateTitleTextStyle}" Text="No captures yet" />
                        <TextBlock
                            x:Name="EmptyStateMessageText"
                            Style="{StaticResource AppEmptyStateBodyTextStyle}"
                            Text="Set a save folder and capture hotkey to get started. Live Draw is configured in Settings and works without a save folder." />
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="GalleryScrollViewer" Visibility="Collapsed">
                    <StackPanel Spacing="{StaticResource AppSpacingSection}">
                        <StackPanel Spacing="{StaticResource AppSpacingContent}">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}">
                                <TextBlock Style="{StaticResource AppContentSectionTitleTextStyle}" Text="Images" />
                                <TextBlock
                                    Style="{StaticResource AppContentCaptionTextStyle}"
                                    Text="Left-click opens the editor. Right-click copies the image to the clipboard."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <GridView
                                x:Name="ImageFilesGridView"
                                IsItemClickEnabled="True"
                                ItemClick="ImageFilesGridView_ItemClick"
                                RightTapped="ImageFilesGridView_RightTapped"
                                SelectionMode="None">
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="280"
                                            Height="220"
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource AppCornerRadiusCard}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border
                                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                    CornerRadius="{StaticResource AppCornerRadiusControl}">
                                                    <Grid>
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="34"
                                                            Text="🖼" />
                                                        <Image
                                                            Source="{Binding Thumbnail}"
                                                            Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel
                                                    Grid.Row="1"
                                                    Margin="0,8,0,0"
                                                    Spacing="{StaticResource AppSpacingTight}">
                                                    <TextBlock
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        Text="{Binding ImageDateLine}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Style="{StaticResource AppContentCaptionTextStyle}"
                                                        Text="{Binding ImageSizeLine}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>

                        <StackPanel Spacing="{StaticResource AppSpacingContent}">
                            <TextBlock Style="{StaticResource AppContentSectionTitleTextStyle}" Text="Other Files" />
                            <ListView
                                x:Name="OtherFilesListView"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource AppCornerRadiusControl}">
                                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingContent}">
                                                <TextBlock
                                                    FontSize="18"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding FileGlyph}" />
                                                <StackPanel>
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Style="{StaticResource AppContentCaptionTextStyle}"
                                                        Text="{Binding FileInfoText}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
