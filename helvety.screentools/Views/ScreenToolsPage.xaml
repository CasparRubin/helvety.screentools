<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.ScreenToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource AppPaddingPageBottomHeavy}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Off-screen host for RenderTargetBitmap when compositing vector overlays onto editable PNG thumbnails.
             Size must cover max decode (520) and stay opaque; 1×1 + Opacity=0 breaks RTB capture of the WriteableBitmap base. -->
        <Grid
            x:Name="ThumbnailCompositionHost"
            Grid.RowSpan="2"
            Width="520"
            Height="520"
            Margin="-10000,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsHitTestVisible="False" />

        <StackPanel Spacing="{StaticResource AppSpacingStack}">
            <TextBlock Style="{StaticResource AppPageTitleTextStyle}" Text="Helvety Screen Tools" />
            <TextBlock
                x:Name="AppHeroDescriptionText"
                Style="{StaticResource AppPageSubtitleTextStyle}"
                Text="Capture your screen with smart snap selection, draw live on your desktop in fullscreen, and edit saved images with crop, blur, highlight, text, borders, and arrows in the built-in editor."
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,16,0,0"
            Padding="{StaticResource AppPaddingCardLarge}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource AppCornerRadiusCard}">
            <Grid>
                <Border
                    x:Name="EmptyFolderCallout"
                    MaxWidth="700"
                    Padding="28"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppCornerRadiusCard}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <StackPanel Spacing="{StaticResource AppSpacingContent}">
                        <TextBlock Style="{StaticResource AppEmptyStateTitleTextStyle}" Text="No captures yet" />
                        <TextBlock
                            x:Name="EmptyStateMessageText"
                            Style="{StaticResource AppEmptyStateBodyTextStyle}"
                            Text="Set a save folder and capture hotkey to get started. Live Draw is configured in Settings and works without a save folder." />
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="GalleryScrollViewer" Visibility="Collapsed">
                    <StackPanel Spacing="{StaticResource AppSpacingContent}">
                        <StackPanel Spacing="{StaticResource AppSpacingTight}">
                            <TextBlock Style="{StaticResource AppContentSectionTitleTextStyle}" Text="Images" />
                            <TextBlock
                                Style="{StaticResource AppContentCaptionTextStyle}"
                                Text="Left-click opens the editor. Right-click copies the image to the clipboard."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <GridView
                            x:Name="ImageFilesGridView"
                            IsItemClickEnabled="True"
                            ItemClick="ImageFilesGridView_ItemClick"
                            RightTapped="ImageFilesGridView_RightTapped"
                            SelectionMode="None">
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="280"
                                        Height="220"
                                        Padding="10"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource AppCornerRadiusCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border
                                                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="{StaticResource AppCornerRadiusControl}">
                                                <Grid>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="34"
                                                        Text="🖼" />
                                                    <Image
                                                        Source="{Binding Thumbnail}"
                                                        Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>

                                            <StackPanel
                                                Grid.Row="1"
                                                Margin="0,8,0,0"
                                                Spacing="{StaticResource AppSpacingTight}">
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding ImageDateLine}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Style="{StaticResource AppContentCaptionTextStyle}"
                                                    Text="{Binding ImageSizeLine}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
