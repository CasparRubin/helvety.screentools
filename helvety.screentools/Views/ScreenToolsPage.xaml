<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.ScreenToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <CollectionViewSource
            x:Name="GroupedImageFilesViewSource"
            IsSourceGrouped="True" />

        <DataTemplate x:Key="GalleryGroupHeaderTemplate">
            <TextBlock
                Margin="0,6,0,8"
                Style="{StaticResource AppContentSectionTitleTextStyle}"
                Text="{Binding Title}" />
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource AppPaddingPageBottomHeavy}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="GlobalHotkeyListenersOffInfoBar"
            Grid.Row="0"
            Margin="0,0,0,12"
            IsClosable="False"
            IsOpen="True"
            Message="Screenshot and Live Draw keyboard shortcuts will not respond while listeners are off."
            Severity="Warning"
            Title="Global hotkeys are turned off"
            Visibility="Collapsed">
            <InfoBar.ActionButton>
                <HyperlinkButton Click="OpenGeneralSettingsForHotkeys_Click" Content="Open General settings" />
            </InfoBar.ActionButton>
        </InfoBar>

        <StackPanel Grid.Row="1" Spacing="{StaticResource AppSpacingStack}">
            <TextBlock Style="{StaticResource AppPageTitleTextStyle}" Text="Helvety Screen Tools" />
            <TextBlock
                x:Name="AppHeroDescriptionText"
                Style="{StaticResource AppPageSubtitleTextStyle}"
                Text="Take screenshots with smart snap selection, draw live on your desktop in fullscreen, and edit saved images with crop, blur, highlight, text, borders, and arrows in the built-in editor."
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid
            Grid.Row="2"
            Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Spacing="{StaticResource AppSpacingTight}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource AppContentSectionTitleTextStyle}"
                        Text="Images" />
                    <Button
                        Grid.Column="1"
                        Click="OpenImagesFolder_Click"
                        Content="Open folder" />
                </Grid>
                <TextBlock
                    Style="{StaticResource AppContentCaptionTextStyle}"
                    Text="Left-click opens the editor. Right-click copies the image to the clipboard."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Margin="0,12,0,0"
                Padding="{StaticResource AppPaddingCardLarge}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppCornerRadiusCard}">
                <Grid>
                    <Border
                        x:Name="EmptyFolderCallout"
                        MaxWidth="700"
                        Padding="28"
                        Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource AppCornerRadiusCard}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <StackPanel Spacing="{StaticResource AppSpacingContent}">
                            <TextBlock Style="{StaticResource AppEmptyStateTitleTextStyle}" Text="No screenshots yet" />
                            <TextBlock
                                x:Name="EmptyStateMessageText"
                                Style="{StaticResource AppEmptyStateBodyTextStyle}"
                                Text="Set a save folder and screenshot hotkey to get started. Live Draw is configured in Settings and works without a save folder." />
                        </StackPanel>
                    </Border>

                    <Grid x:Name="GalleryScrollViewer" Visibility="Collapsed">
                        <GridView
                            x:Name="ImageFilesGridView"
                            IsItemClickEnabled="True"
                            ItemsSource="{Binding Source={StaticResource GroupedImageFilesViewSource}}"
                            ItemClick="ImageFilesGridView_ItemClick"
                            RightTapped="ImageFilesGridView_RightTapped"
                            SelectionMode="None">
                            <GridView.GroupStyle>
                                <GroupStyle HeaderTemplate="{StaticResource GalleryGroupHeaderTemplate}" />
                            </GridView.GroupStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="280"
                                        Height="220"
                                        Padding="10"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource AppCornerRadiusCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border
                                                Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="{StaticResource AppCornerRadiusControl}">
                                                <Grid>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="34"
                                                        Text="🖼" />
                                                    <Image
                                                        Source="{Binding Thumbnail}"
                                                        Stretch="UniformToFill" />
                                                </Grid>
                                            </Border>

                                            <StackPanel
                                                Grid.Row="1"
                                                Margin="0,8,0,0"
                                                Spacing="{StaticResource AppSpacingTight}">
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding ImageDateLine}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Style="{StaticResource AppContentCaptionTextStyle}"
                                                    Text="{Binding ImageSizeLine}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
