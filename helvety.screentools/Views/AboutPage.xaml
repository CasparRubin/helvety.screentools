<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource AppPaddingPageBottomHeavy}" Spacing="{StaticResource AppSpacingSection}">
            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource AppPageTitleTextStyle}" Text="About" />
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Use a global shortcut to capture your screen—snap to a window or drag a rectangle, then save or copy to the clipboard. Draw on your desktop with Live Draw, browse saved captures in a gallery, and open images in the built-in editor to crop, blur, highlight, add text, and more."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Links" />
                <tk:SettingsCard
                    Description="Helvety homepage, products, and news."
                    Header="Developer website">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE774;" />
                    </tk:SettingsCard.HeaderIcon>
                    <HyperlinkButton
                        AutomationProperties.Name="Open helvety.com in the browser"
                        Content="helvety.com"
                        NavigateUri="https://helvety.com/" />
                </tk:SettingsCard>
                <tk:SettingsCard
                    Description="Source code, issues, and how to contribute."
                    Header="Open source on GitHub">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE943;" />
                    </tk:SettingsCard.HeaderIcon>
                    <HyperlinkButton
                        AutomationProperties.Name="Open Helvety Screen Tools on GitHub in the browser"
                        Content="github.com/CasparRubin/helvety.screentools"
                        NavigateUri="https://github.com/CasparRubin/helvety.screentools" />
                </tk:SettingsCard>
                <tk:SettingsCard Header="Build version">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </tk:SettingsCard.HeaderIcon>
                    <TextBlock
                        x:Name="BuildVersionText"
                        FontSize="14"
                        FontWeight="SemiBold"
                        TextWrapping="WrapWholeWords" />
                </tk:SettingsCard>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
