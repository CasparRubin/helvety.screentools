<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="About" />

            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Helvety Screen Tools" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="WinUI 3 desktop app for Windows: frozen-screen capture with snap-to-window selection, full-screen Live Draw overlay, a gallery of saved captures, and a built-in layer image editor."
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource SettingsSectionDescriptionTextStyle}" Text="Build" />
                        <TextBlock
                            Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                            Text="Compile-time stamp (local machine clock when the project was built). Rebuild to refresh."
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="BuildStampText"
                            FontFamily="Consolas"
                            FontSize="14"
                            FontWeight="SemiBold"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Links" />
                    <StackPanel Spacing="4">
                        <HyperlinkButton
                            AutomationProperties.Name="Open helvety.com in the browser"
                            Content="helvety.com"
                            NavigateUri="https://helvety.com/" />
                        <HyperlinkButton
                            AutomationProperties.Name="Open Helvety Screen Tools on GitHub in the browser"
                            Content="github.com/CasparRubin/helvety.screentools"
                            NavigateUri="https://github.com/CasparRubin/helvety.screentools" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
