<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.ScreenshotsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock FontSize="26" FontWeight="SemiBold" Text="Screenshots" />
            <TextBlock
                x:Name="SaveFolderPathText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Margin="0,16,0,0"
            Padding="20"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Border
                    x:Name="EmptyFolderCallout"
                    MaxWidth="700"
                    Padding="28"
                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <StackPanel Spacing="10">
                        <TextBlock
                            FontSize="32"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
                            Text="No Screenshots Yet" />
                        <TextBlock
                            x:Name="EmptyStateMessageText"
                            FontSize="18"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            Text="Configure save location and key-binding to start capturing." />
                    </StackPanel>
                </Border>

                <ScrollViewer x:Name="GalleryScrollViewer" Visibility="Collapsed">
                    <StackPanel Spacing="22">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Images" />
                            <GridView
                                x:Name="ImageFilesGridView"
                                IsItemClickEnabled="True"
                                ItemClick="ImageFilesGridView_ItemClick"
                                SelectionMode="None">
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="280"
                                            Height="220"
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border
                                                    Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                    CornerRadius="8">
                                                    <Grid>
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="34"
                                                            Text="🖼" />
                                                        <Image
                                                            Source="{Binding Thumbnail}"
                                                            Stretch="UniformToFill" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel
                                                    Grid.Row="1"
                                                    Margin="0,8,0,0"
                                                    Spacing="2">
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding FileInfoText}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Other Files" />
                            <ListView
                                x:Name="OtherFilesListView"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="10"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock
                                                    FontSize="18"
                                                    Text="{Binding FileGlyph}" />
                                                <StackPanel>
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding FileInfoText}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
