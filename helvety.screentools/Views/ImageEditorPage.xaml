<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.ImageEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editor="using:helvety.screentools.Editor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource AppPaddingEditorChrome}" RowSpacing="{StaticResource AppSpacingContent}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            MinHeight="122"
            Padding="{StaticResource AppPaddingEditorChrome}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource AppCornerRadiusCard}">
            <Border.Resources>
                <Style BasedOn="{StaticResource SettingsInlineLabelTextStyle}" TargetType="TextBlock" />
                <Style x:Key="ToolSettingItemBorderStyle" TargetType="Border">
                    <Setter Property="Padding" Value="{StaticResource AppPaddingToolSettingItem}" />
                    <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="{StaticResource AppCornerRadiusControl}" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="MinHeight" Value="76" />
                    <Setter Property="Margin" Value="0,0,12,0" />
                </Style>
                <ItemsPanelTemplate x:Key="ToolSettingsItemsPanelTemplate">
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
                <Style x:Key="ToolSettingsItemsControlStyle" TargetType="ItemsControl">
                    <Setter Property="ItemsPanel" Value="{StaticResource ToolSettingsItemsPanelTemplate}" />
                </Style>
            </Border.Resources>
            <Border Height="98">
                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled"
                    ZoomMode="Disabled">
                    <Grid>
                        <ItemsControl
                            x:Name="MoveToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Move" />
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="{StaticResource AppSpacingStack}"
                                        VerticalAlignment="Center">
                                        <Button
                                            x:Name="MoveZoomOutButton"
                                            Width="40"
                                            Height="34"
                                            Click="MoveZoomOutButton_Click">
                                            <SymbolIcon Symbol="Remove" />
                                        </Button>
                                        <Slider
                                            x:Name="MoveZoomSlider"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="180"
                                            Height="34"
                                            Minimum="0.1"
                                            Maximum="8"
                                            StepFrequency="0.05"
                                            TickFrequency="0.25"
                                            Value="1"
                                            ValueChanged="MoveZoomSlider_ValueChanged" />
                                        <Button
                                            x:Name="MoveZoomInButton"
                                            Width="40"
                                            Height="34"
                                            Click="MoveZoomInButton_Click">
                                            <SymbolIcon Symbol="Add" />
                                        </Button>
                                        <TextBlock
                                            x:Name="MoveZoomValueText"
                                            MinWidth="56"
                                            VerticalAlignment="Center"
                                            Text="100%" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </ItemsControl>

                        <ItemsControl
                            x:Name="TextToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}"
                            Visibility="Collapsed">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Edit" />
                                    <Button
                                        x:Name="EditSelectedTextButton"
                                        Width="200"
                                        Height="34"
                                        Click="EditSelectedTextButton_Click"
                                        Content="Edit Selected Text"
                                        Visibility="Collapsed" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Font" />
                                    <ComboBox x:Name="TextFontComboBox" Width="150" Height="34" SelectionChanged="ToolSettingSelectionChanged">
                                        <ComboBoxItem Content="Segoe UI" IsSelected="True" />
                                        <ComboBoxItem Content="Arial" />
                                        <ComboBoxItem Content="Calibri" />
                                        <ComboBoxItem Content="Consolas" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Font color" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <ComboBox x:Name="TextColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                            <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                            <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                            <ComboBoxItem Content="Black" Tag="#FF000000" />
                                            <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                            <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                            <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                                        </ComboBox>
                                        <Button Content="Pick" Height="34" VerticalAlignment="Center" Click="PickTextColorButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Size" />
                                    <Slider
                                        x:Name="TextSizeNumberBox"
                                        Style="{StaticResource SettingsInlineSliderStyle}"
                                        Width="180"
                                        Height="34"
                                        Minimum="8"
                                        Maximum="180"
                                        StepFrequency="1"
                                        TickFrequency="10"
                                        Value="38"
                                        ValueChanged="ToolSettingSliderValueChanged" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Bold" />
                                    <ToggleSwitch
                                        x:Name="TextBoldToggle"
                                        IsOn="True"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="ToolSettingToggled" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Italic" />
                                    <ToggleSwitch
                                        x:Name="TextItalicToggle"
                                        IsOn="False"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="ToolSettingToggled" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Border" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <ToggleSwitch x:Name="TextBorderToggle" IsOn="False" Style="{StaticResource SettingsInlineToggleSwitchStyle}" Toggled="ToolSettingToggled" />
                                        <ComboBox x:Name="TextBorderColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                            <ComboBoxItem Content="White" Tag="#FFFFFFFF" IsSelected="True" />
                                            <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" />
                                            <ComboBoxItem Content="Black" Tag="#FF000000" />
                                            <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                            <ComboBoxItem Content="Custom" Tag="#FFFFFFFF" />
                                        </ComboBox>
                                        <Button Content="Pick" Height="34" VerticalAlignment="Center" Click="PickTextBorderColorButton_Click" />
                                        <Slider
                                            x:Name="TextBorderThicknessNumberBox"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="120"
                                            Height="34"
                                            Minimum="1"
                                            Maximum="24"
                                            StepFrequency="1"
                                            TickFrequency="1"
                                            Value="1"
                                            ValueChanged="ToolSettingSliderValueChanged" />
                                        <TextBlock
                                            x:Name="TextBorderThicknessValueText"
                                            MinWidth="44"
                                            Text="1 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Shadow" />
                                    <ToggleSwitch
                                        x:Name="TextShadowToggle"
                                        IsOn="True"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="ToolSettingToggled" />
                                </StackPanel>
                            </Border>
                        </ItemsControl>

                        <ItemsControl
                            x:Name="BorderToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}"
                            Visibility="Collapsed">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Color" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <ComboBox x:Name="BorderColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                            <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                            <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                            <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                            <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                            <ComboBoxItem Content="Black" Tag="#FF000000" />
                                            <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                                        </ComboBox>
                                        <Button Content="Pick" Height="34" VerticalAlignment="Center" Click="PickBorderColorButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Thickness" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}">
                                        <Slider
                                            x:Name="BorderThicknessNumberBox"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="180"
                                            Height="34"
                                            Minimum="1"
                                            Maximum="24"
                                            StepFrequency="1"
                                            TickFrequency="1"
                                            Value="4"
                                            ValueChanged="ToolSettingSliderValueChanged" />
                                        <TextBlock
                                            x:Name="BorderThicknessValueText"
                                            MinWidth="44"
                                            Text="4 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Corner Radius" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <Slider
                                            x:Name="BorderCornerRadiusSlider"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="180"
                                            VerticalAlignment="Center"
                                            Minimum="0"
                                            Maximum="24"
                                            StepFrequency="1"
                                            TickFrequency="4"
                                            Value="8"
                                            ValueChanged="RegionCornerRadiusSlider_ValueChanged" />
                                        <TextBlock
                                            x:Name="BorderCornerRadiusValueText"
                                            MinWidth="44"
                                            Text="8 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Shadow" />
                                    <ToggleSwitch
                                        x:Name="BorderShadowToggle"
                                        IsOn="True"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="ToolSettingToggled" />
                                </StackPanel>
                            </Border>
                        </ItemsControl>

                        <ItemsControl
                            x:Name="BlurToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}"
                            Visibility="Collapsed">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Radius" />
                                    <Slider
                                        x:Name="BlurRadiusNumberBox"
                                        Style="{StaticResource SettingsInlineSliderStyle}"
                                        Width="180"
                                        Height="34"
                                        Minimum="1"
                                        Maximum="25"
                                        StepFrequency="1"
                                        TickFrequency="2"
                                        Value="6"
                                        ValueChanged="ToolSettingSliderValueChanged" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Corner Radius" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <Slider
                                            x:Name="BlurCornerRadiusSlider"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="180"
                                            VerticalAlignment="Center"
                                            Minimum="0"
                                            Maximum="24"
                                            StepFrequency="1"
                                            TickFrequency="4"
                                            Value="8"
                                            ValueChanged="RegionCornerRadiusSlider_ValueChanged" />
                                        <TextBlock
                                            x:Name="BlurCornerRadiusValueText"
                                            MinWidth="44"
                                            Text="8 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Feather" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <Slider
                                            x:Name="BlurFeatherSlider"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="180"
                                            Height="34"
                                            Minimum="0"
                                            Maximum="40"
                                            StepFrequency="1"
                                            TickFrequency="4"
                                            Value="0"
                                            ValueChanged="ToolSettingSliderValueChanged" />
                                        <TextBlock
                                            x:Name="BlurFeatherValueText"
                                            MinWidth="44"
                                            Text="0 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Invert" />
                                    <ToggleSwitch
                                        x:Name="BlurInvertToggle"
                                        IsOn="False"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="BlurInvertToggle_Toggled" />
                                </StackPanel>
                            </Border>
                        </ItemsControl>

                        <ItemsControl
                            x:Name="HighlightToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}"
                            Visibility="Collapsed">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Dim" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}">
                                        <Slider
                                            x:Name="HighlightDimSlider"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="220"
                                            Minimum="0"
                                            Maximum="80"
                                            StepFrequency="1"
                                            TickFrequency="10"
                                            ValueChanged="HighlightDimSlider_ValueChanged" />
                                        <TextBlock
                                            x:Name="HighlightDimValueText"
                                            MinWidth="56"
                                            Text="35%" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Corner Radius" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <Slider
                                            x:Name="HighlightCornerRadiusSlider"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="180"
                                            VerticalAlignment="Center"
                                            Minimum="0"
                                            Maximum="24"
                                            StepFrequency="1"
                                            TickFrequency="4"
                                            Value="8"
                                            ValueChanged="RegionCornerRadiusSlider_ValueChanged" />
                                        <TextBlock
                                            x:Name="HighlightCornerRadiusValueText"
                                            MinWidth="44"
                                            Text="8 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Invert" />
                                    <ToggleSwitch
                                        x:Name="HighlightInvertToggle"
                                        IsOn="False"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="HighlightInvertToggle_Toggled" />
                                </StackPanel>
                            </Border>
                        </ItemsControl>

                        <ItemsControl
                            x:Name="ArrowToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}"
                            Visibility="Collapsed">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Form" />
                                    <ComboBox x:Name="ArrowFormComboBox" Width="120" Height="34" SelectionChanged="ToolSettingSelectionChanged">
                                        <ComboBoxItem Content="Tapered" Tag="Tapered" IsSelected="True" />
                                        <ComboBoxItem Content="Straight" Tag="Straight" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Size" />
                                    <Slider
                                        x:Name="ArrowThicknessNumberBox"
                                        Style="{StaticResource SettingsInlineSliderStyle}"
                                        Width="180"
                                        Height="34"
                                        Minimum="1"
                                        Maximum="24"
                                        StepFrequency="1"
                                        TickFrequency="1"
                                        Value="4"
                                        ValueChanged="ToolSettingSliderValueChanged" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Color" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <ComboBox x:Name="ArrowColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                            <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" IsSelected="True" />
                                            <ComboBoxItem Content="Blue" Tag="#FF4285F4" />
                                            <ComboBoxItem Content="Orange" Tag="#FFFFA500" />
                                            <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                            <ComboBoxItem Content="Black" Tag="#FF000000" />
                                            <ComboBoxItem Content="Custom" Tag="#FFD81B60" />
                                        </ComboBox>
                                        <Button Content="Pick" Height="34" VerticalAlignment="Center" Click="PickArrowColorButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Border" />
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}" VerticalAlignment="Center">
                                        <ToggleSwitch x:Name="ArrowBorderToggle" IsOn="False" Style="{StaticResource SettingsInlineToggleSwitchStyle}" Toggled="ToolSettingToggled" />
                                        <ComboBox x:Name="ArrowBorderColorComboBox" Width="108" Height="34" VerticalAlignment="Center" SelectionChanged="ToolSettingSelectionChanged">
                                            <ComboBoxItem Content="Black" Tag="#FF000000" />
                                            <ComboBoxItem Content="Fuchsia Red" Tag="#FFD81B60" />
                                            <ComboBoxItem Content="White" Tag="#FFFFFFFF" />
                                            <ComboBoxItem Content="Custom" Tag="#FF000000" IsSelected="True" />
                                        </ComboBox>
                                        <Button Content="Pick" Height="34" VerticalAlignment="Center" Click="PickArrowBorderColorButton_Click" />
                                        <Slider
                                            x:Name="ArrowBorderThicknessNumberBox"
                                            Style="{StaticResource SettingsInlineSliderStyle}"
                                            Width="120"
                                            Height="34"
                                            Minimum="1"
                                            Maximum="8"
                                            StepFrequency="1"
                                            TickFrequency="1"
                                            Value="1"
                                            ValueChanged="ToolSettingSliderValueChanged" />
                                        <TextBlock
                                            x:Name="ArrowBorderThicknessValueText"
                                            MinWidth="44"
                                            Text="1 px" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Shadow" />
                                    <ToggleSwitch
                                        x:Name="ArrowShadowToggle"
                                        IsOn="True"
                                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                                        Toggled="ToolSettingToggled" />
                                </StackPanel>
                            </Border>
                        </ItemsControl>

                        <ItemsControl
                            x:Name="CropToolSettingsPanel"
                            Style="{StaticResource ToolSettingsItemsControlStyle}"
                            Visibility="Collapsed">
                            <Border Style="{StaticResource ToolSettingItemBorderStyle}">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource AppToolSettingCardTitleTextStyle}" Text="Crop" />
                                    <TextBlock Text="Draw a region and save crop from Export." />
                                </StackPanel>
                            </Border>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Border>

        <Grid
            Grid.Row="1"
            ColumnSpacing="{StaticResource AppSpacingContent}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="366" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="{StaticResource AppPaddingToolbarChrome}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppCornerRadiusToolbarChrome}">
                <StackPanel Spacing="{StaticResource AppSpacingStack}">
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Tools" />
                    <StackPanel Spacing="{StaticResource AppSpacingStack}">
                        <Button
                            x:Name="MoveToolButton"
                            Width="124"
                            Height="64"
                            Tag="Move"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE7C9;" />
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Move" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="TextToolButton"
                            Width="124"
                            Height="64"
                            Tag="Text"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8D2;" />
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Text" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="BorderToolButton"
                            Width="124"
                            Height="64"
                            Tag="Border"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Width="20" Height="20">
                                    <Grid Width="20" Height="20">
                                        <Rectangle
                                            Width="16"
                                            Height="12"
                                            RadiusX="2"
                                            RadiusY="2"
                                            Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                            StrokeThickness="1.8" />
                                        <Rectangle
                                            Width="12"
                                            Height="8"
                                            RadiusX="1"
                                            RadiusY="1"
                                            Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                            StrokeThickness="1.2"
                                            Opacity="0.65" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Border" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="BlurToolButton"
                            Width="124"
                            Height="64"
                            Tag="Blur"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Width="20" Height="20">
                                    <Grid Width="20" Height="20">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="2,0,0,0"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                            Opacity="0.55" />
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,2,0"
                                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                                            Opacity="0.55" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Blur" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="HighlightToolButton"
                            Width="124"
                            Height="64"
                            Tag="Highlight"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE790;" />
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Highlight" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="ArrowToolButton"
                            Width="124"
                            Height="64"
                            Tag="Arrow"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <SymbolIcon Symbol="Forward" />
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Arrow" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="CropToolButton"
                            Width="124"
                            Height="64"
                            Tag="Crop"
                            Click="ToolButton_Click">
                            <StackPanel Spacing="{StaticResource AppSpacingTight}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE7A8;" />
                                <TextBlock Style="{StaticResource AppEditorToolLabelTextStyle}" Text="Crop" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="{StaticResource AppPaddingEditorCanvasInset}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource AppCornerRadiusToolbarChrome}">
                <ScrollViewer
                    x:Name="EditorScrollViewer"
                    HorizontalScrollBarVisibility="Visible"
                    VerticalScrollBarVisibility="Auto"
                    ZoomMode="Enabled">
                    <Grid
                        x:Name="EditorSurfaceGrid"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <Image
                            x:Name="BaseImage"
                            Stretch="None" />
                        <Canvas
                            x:Name="LayersCanvas"
                            IsHitTestVisible="False" />
                        <Canvas
                            x:Name="OverlayCanvas"
                            Background="Transparent"
                            DoubleTapped="OverlayCanvas_DoubleTapped"
                            PointerPressed="OverlayCanvas_PointerPressed"
                            PointerMoved="OverlayCanvas_PointerMoved"
                            PointerReleased="OverlayCanvas_PointerReleased" />
                    </Grid>
                </ScrollViewer>
            </Border>

            <Grid
                Grid.Column="2"
                RowSpacing="{StaticResource AppSpacingContent}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Padding="{StaticResource AppPaddingToolbarChrome}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppCornerRadiusToolbarChrome}">
                    <Grid RowSpacing="{StaticResource AppSpacingContent}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource SettingsSubsectionTitleTextStyle}"
                            Text="Layers" />
                        <ListView
                            Grid.Row="1"
                            x:Name="LayersListView"
                            SelectionMode="Single"
                            CanDragItems="True"
                            CanReorderItems="True"
                            AllowDrop="True"
                            HorizontalContentAlignment="Stretch"
                            DragItemsCompleted="LayersListView_DragItemsCompleted"
                            SelectionChanged="LayersListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="editor:EditorLayer">
                                    <Border
                                        Padding="{StaticResource AppPaddingListRow}"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource AppCornerRadiusControl}">
                                        <Grid ColumnSpacing="{StaticResource AppSpacingStack}" MinHeight="48">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid
                                                ColumnSpacing="{StaticResource AppSpacingStack}"
                                                VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ToggleButton
                                                    Grid.Column="0"
                                                    IsChecked="{x:Bind IsVisible, Mode=TwoWay}"
                                                    Checked="LayerVisibilityCheckBox_Changed"
                                                    Unchecked="LayerVisibilityCheckBox_Changed"
                                                    Tag="{x:Bind Id}">
                                                    <SymbolIcon Symbol="View" />
                                                </ToggleButton>
                                                <StackPanel Grid.Column="1" Spacing="1">
                                                    <TextBlock
                                                        Style="{StaticResource AppListItemTitleTextStyle}"
                                                        Text="{x:Bind Name}" />
                                                    <TextBlock
                                                        Style="{StaticResource AppListItemCaptionTextStyle}"
                                                        Text="{x:Bind LayerType}" />
                                                </StackPanel>
                                            </Grid>
                                            <Button
                                                Grid.Column="1"
                                                Click="RemoveLayerButton_Click"
                                                Tag="{x:Bind Id}"
                                                ToolTipService.ToolTip="Delete layer">
                                                <SymbolIcon Symbol="Delete" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="{StaticResource AppPaddingCardCompact}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppCornerRadiusToolbarChrome}">
                    <StackPanel Spacing="{StaticResource AppSpacingContent}">
                        <TextBlock
                            Style="{StaticResource SettingsSubsectionTitleTextStyle}"
                            Text="Export" />
                        <Border
                            Height="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Opacity="0.75" />
                        <StackPanel Spacing="{StaticResource AppSpacingStack}">
                            <Button
                                x:Name="SaveCopyAndCloseButton"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="36"
                                HorizontalAlignment="Stretch"
                                Click="SaveCopyAndCloseButton_Click"
                                Content="Save, copy and close" />
                            <Button
                                x:Name="SaveAndCloseButton"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="36"
                                HorizontalAlignment="Stretch"
                                Click="SaveAndCloseButton_Click"
                                Content="Save and close" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</Page>
