<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.Settings.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource AppPaddingPageBottomHeavy}" Spacing="{StaticResource AppSpacingSection}">
            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsPageTitleTextStyle}" Text="General" />
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Window, system tray, and image editor performance."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Window" />
                <tk:SettingsCard
                    Description="Keep Helvety Screen Tools running when you close the window so global hotkeys keep working."
                    Header="System tray">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7E8;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="MinimizeToTrayToggle"
                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                        Toggled="MinimizeToTrayToggle_Toggled" />
                </tk:SettingsCard>
            </StackPanel>

            <StackPanel x:Name="RunAtSignInSection" Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Startup" />
                <tk:SettingsCard
                    Description="Launch Helvety Screen Tools when you sign in to Windows so tray and global hotkeys are ready. This also appears under Windows Settings → Apps → Startup."
                    Header="Run at sign-in">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7B5;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="RunAtSignInToggle"
                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                        Toggled="RunAtSignInToggle_Toggled" />
                </tk:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Image editor" />
                <tk:SettingsCard
                    Description="Reduces expensive effects while dragging or resizing for smoother editing. Disable only if you need full preview during movement."
                    Header="Editor performance mode">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE9F5;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="EditorPerformanceModeToggle"
                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                        Toggled="EditorPerformanceModeToggle_Toggled" />
                </tk:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Animations" />
                <tk:SettingsCard
                    Description="How strong the animated selection border looks (same for capture and Live Draw)."
                    Header="Snap border intensity">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE790;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ComboBox
                        x:Name="BorderIntensityComboBox"
                        MinWidth="{StaticResource SettingActionControlMinWidth}"
                        IsTextSearchEnabled="False"
                        SelectionChanged="BorderIntensityComboBox_SelectionChanged"
                        Style="{StaticResource SettingsInlineComboBoxStyle}">
                        <ComboBoxItem Content="Subtle" Tag="Subtle" />
                        <ComboBoxItem Content="Balanced" Tag="Balanced" />
                        <ComboBoxItem Content="Bold" Tag="Bold" />
                    </ComboBox>
                </tk:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Danger zone" />
                <tk:SettingsCard
                    Description="Restores all preferences to defaults (including hotkeys, editor settings, snap-border intensity, Live Draw, capture quality, and save folder to the default desktop captures folder). Does not delete image files already on disk."
                    Header="Reset all settings">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE74D;" />
                    </tk:SettingsCard.HeaderIcon>
                    <Button
                        x:Name="ResetSettingsButton"
                        Click="ResetSettingsButton_Click"
                        Content="Reset to defaults"
                        Style="{StaticResource SettingsInlineButtonStyle}" />
                </tk:SettingsCard>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
