<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.Settings.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource AppPaddingPageBottomHeavy}" Spacing="{StaticResource AppSpacingSection}">
            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsPageTitleTextStyle}" Text="General" />
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Save location and storage for your captures."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <tk:SettingsCard
                Description="Choose where captures are stored. A writable folder is required for frozen-screen capture."
                Header="Save location">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B7;" />
                </tk:SettingsCard.HeaderIcon>
                <StackPanel Spacing="{StaticResource AppSpacingContent}" MinWidth="{StaticResource SettingActionControlMinWidth}">
                    <TextBlock
                        x:Name="SaveFolderText"
                        Text="Save Folder: (loading...)"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}">
                        <Button
                            x:Name="ChooseSaveFolderButton"
                            Click="ChooseSaveFolderButton_Click"
                            Content="Choose folder"
                            Style="{StaticResource SettingsInlineButtonStyle}" />
                        <Button
                            x:Name="UseDefaultSaveFolderButton"
                            Click="UseDefaultSaveFolderButton_Click"
                            Content="Use default"
                            Style="{StaticResource SettingsInlineButtonStyle}" />
                        <Button
                            x:Name="RemoveSaveFolderButton"
                            Click="RemoveSaveFolderButton_Click"
                            Content="Remove"
                            Style="{StaticResource SettingsInlineButtonStyle}" />
                    </StackPanel>
                    <TextBlock
                        x:Name="SaveFolderStatusText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="" />
                </StackPanel>
            </tk:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
