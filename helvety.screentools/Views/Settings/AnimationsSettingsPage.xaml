<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.Settings.AnimationsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource AppPaddingPageBottomHeavy}" Spacing="{StaticResource AppSpacingSection}">
            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsPageTitleTextStyle}" Text="Animations" />
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Shared snap-border chrome for frozen-screen capture and Live Draw: gradients, dashing, and pulse. Changes apply the next time you open capture or Live Draw."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Snap border" />
            <tk:SettingsCard
                Description="How strong the animated selection border looks (same for capture and Live Draw)."
                Header="Intensity">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE790;" />
                </tk:SettingsCard.HeaderIcon>
                <ComboBox
                    x:Name="BorderIntensityComboBox"
                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                    IsTextSearchEnabled="False"
                    SelectionChanged="BorderIntensityComboBox_SelectionChanged"
                    Style="{StaticResource SettingsInlineComboBoxStyle}">
                    <ComboBoxItem Content="Subtle" Tag="Subtle" />
                    <ComboBoxItem Content="Balanced" Tag="Balanced" />
                    <ComboBoxItem Content="Bold" Tag="Bold" />
                </ComboBox>
            </tk:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
