<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.Settings.CaptureModeSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource AppPaddingPageBottomHeavy}" Spacing="{StaticResource AppSpacingSection}">
            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsPageTitleTextStyle}" Text="Capture mode" />
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Frozen overlay capture: snapping, rectangle selection, border effects, and quality."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Behavior" />
            <tk:SettingsCard
                Description="Click without dragging saves the snapped window (or full virtual screen); drag to draw a rectangle. Left-click saves, copies, and exits; right-click saves without copying and stays in capture mode."
                Header="How capture works">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7B5;" />
                </tk:SettingsCard.HeaderIcon>
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Use Screen capture to set your global shortcut."
                    TextWrapping="WrapWholeWords" />
            </tk:SettingsCard>

            <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Border effects" />
            <tk:SettingsCard
                Description="Control the visual intensity of capture border animations."
                Header="Intensity">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE790;" />
                </tk:SettingsCard.HeaderIcon>
                <ComboBox
                    x:Name="BorderIntensityComboBox"
                    Style="{StaticResource SettingsInlineComboBoxStyle}"
                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                    IsTextSearchEnabled="False"
                    SelectionChanged="BorderIntensityComboBox_SelectionChanged">
                    <ComboBoxItem Content="Subtle" Tag="Subtle" />
                    <ComboBoxItem Content="Balanced" Tag="Balanced" />
                    <ComboBoxItem Content="Bold" Tag="Bold" />
                </ComboBox>
            </tk:SettingsCard>

            <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Capture quality" />
            <tk:SettingsCard
                Description="Fast is default. Optimized improves text; Heavy uses heavier processing on large selections."
                Header="Quality mode">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE9A9;" />
                </tk:SettingsCard.HeaderIcon>
                <ComboBox
                    x:Name="ScreenshotQualityModeComboBox"
                    Style="{StaticResource SettingsInlineComboBoxStyle}"
                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                    IsTextSearchEnabled="False"
                    SelectionChanged="ScreenshotQualityModeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Fast" Tag="Fast" />
                    <ComboBoxItem Content="Optimized" Tag="Optimized" />
                    <ComboBoxItem Content="Heavy" Tag="Heavy" />
                </ComboBox>
            </tk:SettingsCard>

            <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Overlay" />
            <tk:SettingsCard
                Description="Show helper instructions in the capture overlay."
                Header="Instructions">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </tk:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="ShowOverlayInstructionsToggle"
                    Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                    OffContent="Off"
                    OnContent="On"
                    Toggled="ShowOverlayInstructionsToggle_Toggled" />
            </tk:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
