<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.Settings.CaptureHotkeySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:helvety.screentools.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource AppPaddingPageBottomHeavy}" Spacing="{StaticResource AppSpacingSection}">
            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsPageTitleTextStyle}" Text="Screen capture" />
                <TextBlock
                    Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                    Text="Enable or disable capture, choose a save folder, set capture quality and overlay instructions, and use the Shortcut section below for your global hotkey. Snap-border animation intensity (shared with Live Draw) is under Settings → General. In the capture overlay, click without dragging to save the snapped window or the full virtual screen; drag to draw a rectangle. Left-click saves, copies to the clipboard, and exits; right-click saves without copying and stays in capture mode."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <tk:SettingsCard
                Description="When off, the capture shortcut is not active. Your saved keys remain stored."
                Header="Screen capture">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE722;" />
                </tk:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="CaptureModuleToggle"
                    Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                    Toggled="CaptureModuleToggle_Toggled" />
            </tk:SettingsCard>

            <tk:SettingsCard
                x:Name="SaveLocationCard"
                Description="Save Folder: (loading...)"
                Header="Save location">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B7;" />
                </tk:SettingsCard.HeaderIcon>
                <StackPanel Spacing="{StaticResource AppSpacingTight}" MinWidth="{StaticResource SettingActionControlMinWidth}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingStack}">
                        <Button
                            x:Name="ChooseSaveFolderButton"
                            Click="ChooseSaveFolderButton_Click"
                            Content="Choose folder"
                            Style="{StaticResource SettingsInlineButtonStyle}" />
                        <Button
                            x:Name="UseDefaultSaveFolderButton"
                            Click="UseDefaultSaveFolderButton_Click"
                            Content="Use default"
                            Style="{StaticResource SettingsInlineButtonStyle}" />
                        <Button
                            x:Name="RemoveSaveFolderButton"
                            Click="RemoveSaveFolderButton_Click"
                            Content="Remove"
                            Style="{StaticResource SettingsInlineButtonStyle}" />
                    </StackPanel>
                    <TextBlock
                        x:Name="SaveFolderStatusText"
                        Visibility="Collapsed"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="" />
                </StackPanel>
            </tk:SettingsCard>

            <ContentControl x:Name="CaptureDetailsPanel" Style="{StaticResource AppSettingsDetailHostStyle}">
                <StackPanel Spacing="{StaticResource AppSpacingSection}">
                    <StackPanel Spacing="{StaticResource AppSpacingStack}">
                        <TextBlock
                            Style="{StaticResource SettingsSubsectionTitleTextStyle}"
                            Text="Shortcut" />

                        <tk:SettingsCard
                            Description="The shortcut that is currently active when capture is enabled."
                            Header="Current shortcut">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEDA7;" />
                            </tk:SettingsCard.HeaderIcon>
                            <controls:HotkeyChordStrip x:Name="CaptureCurrentChordStrip" />
                        </tk:SettingsCard>

                        <tk:SettingsCard Description="Hold these while pressing the sequence keys." Header="Modifiers">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xEDA7;" />
                            </tk:SettingsCard.HeaderIcon>
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource AppSpacingContent}">
                                <CheckBox
                                    x:Name="CtrlModifierCheckBox"
                                    Checked="ModifierCheckBox_Changed"
                                    Content="Ctrl"
                                    Unchecked="ModifierCheckBox_Changed" />
                                <CheckBox
                                    x:Name="AltModifierCheckBox"
                                    Checked="ModifierCheckBox_Changed"
                                    Content="Alt"
                                    Unchecked="ModifierCheckBox_Changed" />
                                <CheckBox
                                    x:Name="ShiftModifierCheckBox"
                                    Checked="ModifierCheckBox_Changed"
                                    Content="Shift"
                                    Unchecked="ModifierCheckBox_Changed" />
                            </StackPanel>
                        </tk:SettingsCard>

                        <tk:SettingsExpander Description="Set one to five keys in order. Use Listen to record a key per step." Header="Activation sequence">
                            <tk:SettingsExpander.HeaderIcon>
                                <FontIcon Glyph="&#xEDA7;" />
                            </tk:SettingsExpander.HeaderIcon>
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard Header="Steps">
                                    <Grid ColumnSpacing="{StaticResource AppSpacingContent}" RowSpacing="{StaticResource AppSpacingStack}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Step 1" />
                                <controls:HotkeyChordStrip x:Name="Step1KeyChordStrip" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" />
                                <Button
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Click="ListenStep1Button_Click"
                                    Content="Listen"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />
                                <Button
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Click="ClearStep1Button_Click"
                                    Content="Clear"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Step 2" />
                                <controls:HotkeyChordStrip x:Name="Step2KeyChordStrip" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" />
                                <Button
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Click="ListenStep2Button_Click"
                                    Content="Listen"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />
                                <Button
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Click="ClearStep2Button_Click"
                                    Content="Clear"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Step 3" />
                                <controls:HotkeyChordStrip x:Name="Step3KeyChordStrip" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" />
                                <Button
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Click="ListenStep3Button_Click"
                                    Content="Listen"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />
                                <Button
                                    Grid.Row="2"
                                    Grid.Column="3"
                                    Click="ClearStep3Button_Click"
                                    Content="Clear"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Step 4" />
                                <controls:HotkeyChordStrip x:Name="Step4KeyChordStrip" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" />
                                <Button
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Click="ListenStep4Button_Click"
                                    Content="Listen"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />
                                <Button
                                    Grid.Row="3"
                                    Grid.Column="3"
                                    Click="ClearStep4Button_Click"
                                    Content="Clear"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Step 5" />
                                <controls:HotkeyChordStrip x:Name="Step5KeyChordStrip" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" />
                                <Button
                                    Grid.Row="4"
                                    Grid.Column="2"
                                    Click="ListenStep5Button_Click"
                                    Content="Listen"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />
                                <Button
                                    Grid.Row="4"
                                    Grid.Column="3"
                                    Click="ClearStep5Button_Click"
                                    Content="Clear"
                                    Style="{StaticResource SettingsInlineButtonStyle}" />
                                    </Grid>
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>

                        <InfoBar
                            x:Name="ListeningInfoBar"
                            IsClosable="False"
                            IsOpen="False"
                            Message="Press a non-modifier key. Esc cancels."
                            Severity="Informational"
                            Title="Listening for key" />
                        <TextBlock
                            x:Name="BindingStatusText"
                            Visibility="Collapsed"
                            Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                            Text="" />
                    </StackPanel>
                </StackPanel>
            </ContentControl>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Capture quality" />
                <tk:SettingsCard
                    Description="Fast is default. Optimized improves text; Heavy uses heavier processing on large selections."
                    Header="Quality mode">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE9A9;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ComboBox
                        x:Name="ScreenshotQualityModeComboBox"
                        Style="{StaticResource SettingsInlineComboBoxStyle}"
                        MinWidth="{StaticResource SettingActionControlMinWidth}"
                        IsTextSearchEnabled="False"
                        SelectionChanged="ScreenshotQualityModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Fast" Tag="Fast" />
                        <ComboBoxItem Content="Optimized" Tag="Optimized" />
                        <ComboBoxItem Content="Heavy" Tag="Heavy" />
                    </ComboBox>
                </tk:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="{StaticResource AppSpacingStack}">
                <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Overlay" />
                <tk:SettingsCard
                    Description="Show helper instructions in the capture overlay."
                    Header="Instructions">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        x:Name="ShowOverlayInstructionsToggle"
                        Style="{StaticResource SettingsInlineToggleSwitchStyle}"
                        Toggled="ShowOverlayInstructionsToggle_Toggled" />
                </tk:SettingsCard>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
