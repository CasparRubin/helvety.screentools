<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Settings" />

            <!-- Save Location -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Save Location" />
                            <TextBlock
                                Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                                Text="Choose where screenshots are stored."
                                />
                            <TextBlock
                                x:Name="SaveFolderText"
                                Text="Save Folder: (loading...)"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                            <Button
                                x:Name="ChooseSaveFolderButton"
                                Style="{StaticResource SettingsInlineButtonStyle}"
                                Click="ChooseSaveFolderButton_Click"
                                Content="Choose Folder" />
                            <Button
                                x:Name="UseDefaultSaveFolderButton"
                                Style="{StaticResource SettingsInlineButtonStyle}"
                                Click="UseDefaultSaveFolderButton_Click"
                                Content="Use Default" />
                            <Button
                                x:Name="RemoveSaveFolderButton"
                                Style="{StaticResource SettingsInlineButtonStyle}"
                                Click="RemoveSaveFolderButton_Click"
                                Content="Remove Save Location" />
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        x:Name="SaveFolderStatusText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                </StackPanel>
            </Border>

            <!-- Key-Bindings / Hotkeys -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Style="{StaticResource SettingsSectionTitleTextStyle}"
                        Text="Key-Bindings / Hotkeys" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Set modifiers and capture 1-5 sequence keys."
                        />
                    <TextBlock
                        x:Name="CurrentBindingText"
                        Text="Current Binding: Shift+S+S+S"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <CheckBox
                            x:Name="CtrlModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="ModifierCheckBox_Changed"
                            Content="Ctrl"
                            Unchecked="ModifierCheckBox_Changed" />
                        <CheckBox
                            x:Name="AltModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="ModifierCheckBox_Changed"
                            Content="Alt"
                            Unchecked="ModifierCheckBox_Changed" />
                        <CheckBox
                            x:Name="ShiftModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="ModifierCheckBox_Changed"
                            Content="Shift"
                            Unchecked="ModifierCheckBox_Changed" />
                    </StackPanel>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Step 1" />
                        <TextBlock x:Name="Step1KeyText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="0" Grid.Column="2" Click="ListenStep1Button_Click" Content="Listen" />
                        <Button Grid.Row="0" Grid.Column="3" Click="ClearStep1Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Step 2" />
                        <TextBlock x:Name="Step2KeyText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="1" Grid.Column="2" Click="ListenStep2Button_Click" Content="Listen" />
                        <Button Grid.Row="1" Grid.Column="3" Click="ClearStep2Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Step 3" />
                        <TextBlock x:Name="Step3KeyText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="2" Grid.Column="2" Click="ListenStep3Button_Click" Content="Listen" />
                        <Button Grid.Row="2" Grid.Column="3" Click="ClearStep3Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Step 4" />
                        <TextBlock x:Name="Step4KeyText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="3" Grid.Column="2" Click="ListenStep4Button_Click" Content="Listen" />
                        <Button Grid.Row="3" Grid.Column="3" Click="ClearStep4Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Step 5" />
                        <TextBlock x:Name="Step5KeyText" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="4" Grid.Column="2" Click="ListenStep5Button_Click" Content="Listen" />
                        <Button Grid.Row="4" Grid.Column="3" Click="ClearStep5Button_Click" Content="Clear" />
                    </Grid>

                    <InfoBar
                        x:Name="ListeningInfoBar"
                        IsClosable="False"
                        IsOpen="False"
                        Message="Click Listen on a step, then press a key."
                        Severity="Informational"
                        Title="Listening for key" />
                    <TextBlock
                        x:Name="CaptureInstructionText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                    <TextBlock
                        x:Name="CapturePreviewText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                    <TextBlock
                        x:Name="BindingStatusText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <Button
                            x:Name="ApplyHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="ApplyHotkeyButton_Click"
                            Content="Apply Hotkey" />
                        <Button
                            x:Name="UseDefaultHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="UseDefaultHotkeyButton_Click"
                            Content="Use Default" />
                        <Button
                            x:Name="RemoveHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="RemoveHotkeyButton_Click"
                            Content="Remove Hotkey" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Screenshot Mode -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Screenshot Mode" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Capture behavior is fixed: left-click saves, copies to clipboard, and exits screenshot mode; right-click saves and keeps screenshot mode active."
                        />

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Border Effects" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Control the visual intensity of screenshot border animations."
                        />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <TextBlock Style="{StaticResource SettingsInlineLabelTextStyle}" Text="Intensity" />
                        <ComboBox
                            x:Name="BorderIntensityComboBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Height="34"
                            IsTextSearchEnabled="False"
                            MinWidth="170"
                            SelectionChanged="BorderIntensityComboBox_SelectionChanged">
                            <ComboBoxItem Content="Subtle" Tag="Subtle" />
                            <ComboBoxItem Content="Balanced" Tag="Balanced" />
                            <ComboBoxItem Content="Bold" Tag="Bold" />
                        </ComboBox>
                    </StackPanel>

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Capture Quality Mode" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Choose screenshot enhancement level. Fast is quickest, Optimized improves text readability, Heavy applies stronger processing."
                        />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <TextBlock Style="{StaticResource SettingsInlineLabelTextStyle}" Text="Mode" />
                        <ComboBox
                            x:Name="ScreenshotQualityModeComboBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Height="34"
                            IsTextSearchEnabled="False"
                            MinWidth="190"
                            SelectionChanged="ScreenshotQualityModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Fast" Tag="Fast" />
                            <ComboBoxItem Content="Optimized" Tag="Optimized" />
                            <ComboBoxItem Content="Heavy" Tag="Heavy" />
                        </ComboBox>
                    </StackPanel>

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Overlay Checkbox" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Choose whether helper instructions appear in the screenshot overlay."
                        />
                    <CheckBox
                        x:Name="ShowOverlayInstructionsCheckBox"
                        Style="{StaticResource SettingsInlineControlStyle}"
                        Checked="ShowOverlayInstructionsCheckBox_Changed"
                        Content="Show screenshot mode overlay instructions"
                        Unchecked="ShowOverlayInstructionsCheckBox_Changed" />
                </StackPanel>
            </Border>

            <!-- App Behavior -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="App Behavior" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Choose whether closing the window keeps Helvety Screen Tools running in the notification area so global hotkeys continue working."
                        />
                    <CheckBox
                        x:Name="MinimizeToTrayOnCloseCheckBox"
                        Style="{StaticResource SettingsInlineControlStyle}"
                        Checked="MinimizeToTrayOnCloseCheckBox_Changed"
                        Content="Keep app running in notification area when window is closed"
                        Unchecked="MinimizeToTrayOnCloseCheckBox_Changed" />

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Editor Performance Mode" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Enabled (recommended): keeps editing interactions smoother by temporarily reducing expensive visual effects while dragging or resizing. Disable only if you need to always preview full shadows/borders during movement."
                        TextWrapping="WrapWholeWords" />
                    <CheckBox
                        x:Name="EditorPerformanceModeCheckBox"
                        Style="{StaticResource SettingsInlineControlStyle}"
                        Checked="EditorPerformanceModeCheckBox_Changed"
                        Content="Enable Editor Performance Mode"
                        Unchecked="EditorPerformanceModeCheckBox_Changed" />
                </StackPanel>
            </Border>

            <!-- Danger Zone -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Danger Zone" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Reset all app settings to defaults. This removes saved app configuration (save location, hotkeys, border effects, capture quality mode, and related preferences) but does not delete screenshots."
                        />
                    <Button
                        x:Name="ResetSettingsButton"
                        Style="{StaticResource SettingsInlineButtonStyle}"
                        Click="ResetSettingsButton_Click"
                        Content="Reset to Defaults" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
