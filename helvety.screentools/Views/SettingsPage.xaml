<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screentools.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Settings" />

            <!-- Save Location -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Save Location" />
                            <TextBlock
                                Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                                Text="Choose where captures are stored."
                                />
                            <TextBlock
                                x:Name="SaveFolderText"
                                Text="Save Folder: (loading...)"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                            <Button
                                x:Name="ChooseSaveFolderButton"
                                Style="{StaticResource SettingsInlineButtonStyle}"
                                Click="ChooseSaveFolderButton_Click"
                                Content="Choose Folder" />
                            <Button
                                x:Name="UseDefaultSaveFolderButton"
                                Style="{StaticResource SettingsInlineButtonStyle}"
                                Click="UseDefaultSaveFolderButton_Click"
                                Content="Use default" />
                            <Button
                                x:Name="RemoveSaveFolderButton"
                                Style="{StaticResource SettingsInlineButtonStyle}"
                                Click="RemoveSaveFolderButton_Click"
                                Content="Remove Save Location" />
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        x:Name="SaveFolderStatusText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                </StackPanel>
            </Border>

            <!-- Key-Bindings / Hotkeys -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Style="{StaticResource SettingsSectionTitleTextStyle}"
                        Text="Capture hotkey" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Starts frozen-screen capture. Set modifiers and one to five keys in order. A writable save folder is required to apply, use default, or use Listen."
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="CurrentBindingText"
                        Text="Capture hotkey: (loading…)"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <CheckBox
                            x:Name="CtrlModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="ModifierCheckBox_Changed"
                            Content="Ctrl"
                            Unchecked="ModifierCheckBox_Changed" />
                        <CheckBox
                            x:Name="AltModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="ModifierCheckBox_Changed"
                            Content="Alt"
                            Unchecked="ModifierCheckBox_Changed" />
                        <CheckBox
                            x:Name="ShiftModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="ModifierCheckBox_Changed"
                            Content="Shift"
                            Unchecked="ModifierCheckBox_Changed" />
                    </StackPanel>

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Step 1" />
                        <TextBlock x:Name="Step1KeyText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="0" Grid.Column="2" Click="ListenStep1Button_Click" Content="Listen" />
                        <Button Grid.Row="0" Grid.Column="3" Click="ClearStep1Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Step 2" />
                        <TextBlock x:Name="Step2KeyText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="1" Grid.Column="2" Click="ListenStep2Button_Click" Content="Listen" />
                        <Button Grid.Row="1" Grid.Column="3" Click="ClearStep2Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Step 3" />
                        <TextBlock x:Name="Step3KeyText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="2" Grid.Column="2" Click="ListenStep3Button_Click" Content="Listen" />
                        <Button Grid.Row="2" Grid.Column="3" Click="ClearStep3Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Step 4" />
                        <TextBlock x:Name="Step4KeyText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="3" Grid.Column="2" Click="ListenStep4Button_Click" Content="Listen" />
                        <Button Grid.Row="3" Grid.Column="3" Click="ClearStep4Button_Click" Content="Clear" />

                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Step 5" />
                        <TextBlock x:Name="Step5KeyText" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="4" Grid.Column="2" Click="ListenStep5Button_Click" Content="Listen" />
                        <Button Grid.Row="4" Grid.Column="3" Click="ClearStep5Button_Click" Content="Clear" />
                    </Grid>

                    <InfoBar
                        x:Name="ListeningInfoBar"
                        IsClosable="False"
                        IsOpen="False"
                        Message="Click Listen on a step, then press a key."
                        Severity="Informational"
                        Title="Listening for key" />
                    <TextBlock
                        x:Name="CaptureInstructionText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                    <TextBlock
                        x:Name="CapturePreviewText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                    <TextBlock
                        x:Name="BindingStatusText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text=""
                        />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <Button
                            x:Name="ApplyHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="ApplyHotkeyButton_Click"
                            Content="Apply capture hotkey" />
                        <Button
                            x:Name="UseDefaultHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="UseDefaultHotkeyButton_Click"
                            Content="Use default" />
                        <Button
                            x:Name="RemoveHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="RemoveHotkeyButton_Click"
                            Content="Remove capture hotkey" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live Draw hotkey -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Live Draw" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Full-screen Live Draw overlay: transparent to your desktop (GDI chroma key under transparent WinUI; no desktop snapshot). No save folder. Esc exits. Straight-line strokes (e.g. Ctrl+drag when Shift is the rectangle modifier) use a uniform line, not a tapered arrow shaft. Default Rectangle modifier is Shift: Shift+drag draws rectangles; Alt+drag (without Ctrl) draws arrows; Ctrl+drag draws straight lines (no arrowhead). If Rectangle modifier is Alt: Alt alone (without Ctrl) selects rectangles; Shift+drag draws arrows; Ctrl+drag draws straight lines. If it is Ctrl: Ctrl+drag selects rectangles; Alt or Shift (without Ctrl) draws arrows; straight line via Ctrl is unavailable. If it is Win: Win+drag selects rectangles; Alt or Shift (without Ctrl) draws arrows; Ctrl+drag draws straight lines. Drag without a matching shape-tool modifier is freehand. Right-click (no modifiers) shows a pulsing sparkle at the pointer while the button is held; it follows the pointer if you move. Shift+right drag draws a circle; Alt+right drag (without Ctrl) draws an ellipse; if both Shift and Alt are held, Shift+right wins. These right-button shortcuts are fixed and do not follow the rectangle modifier setting (that setting applies to left-button tools only). All shape tools share the same animated styling (gradients, dashing, pulse) as capture border effects."
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        x:Name="LiveDrawCurrentBindingText"
                        Text="Live Draw: Shift+D+D+D"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock Style="{StaticResource SettingsSectionDescriptionTextStyle}" Text="Rectangle modifier (left mouse, while drawing)" />
                    <ComboBox
                        x:Name="LiveDrawRectangleModifierComboBox"
                        SelectionChanged="LiveDrawRectangleModifierComboBox_SelectionChanged">
                        <ComboBoxItem Content="Shift" Tag="Shift" />
                        <ComboBoxItem Content="Ctrl" Tag="Control" />
                        <ComboBoxItem Content="Alt" Tag="Alt" />
                        <ComboBoxItem Content="Win" Tag="Win" />
                    </ComboBox>
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <CheckBox
                            x:Name="LiveDrawCtrlModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="LiveDrawModifierCheckBox_Changed"
                            Content="Ctrl"
                            Unchecked="LiveDrawModifierCheckBox_Changed" />
                        <CheckBox
                            x:Name="LiveDrawAltModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="LiveDrawModifierCheckBox_Changed"
                            Content="Alt"
                            Unchecked="LiveDrawModifierCheckBox_Changed" />
                        <CheckBox
                            x:Name="LiveDrawShiftModifierCheckBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Checked="LiveDrawModifierCheckBox_Changed"
                            Content="Shift"
                            Unchecked="LiveDrawModifierCheckBox_Changed" />
                    </StackPanel>
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Step 1" />
                        <TextBlock x:Name="LiveDrawStep1KeyText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="0" Grid.Column="2" Click="LiveDrawListenStep1Button_Click" Content="Listen" />
                        <Button Grid.Row="0" Grid.Column="3" Click="LiveDrawClearStep1Button_Click" Content="Clear" />
                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Step 2" />
                        <TextBlock x:Name="LiveDrawStep2KeyText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="1" Grid.Column="2" Click="LiveDrawListenStep2Button_Click" Content="Listen" />
                        <Button Grid.Row="1" Grid.Column="3" Click="LiveDrawClearStep2Button_Click" Content="Clear" />
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Step 3" />
                        <TextBlock x:Name="LiveDrawStep3KeyText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="2" Grid.Column="2" Click="LiveDrawListenStep3Button_Click" Content="Listen" />
                        <Button Grid.Row="2" Grid.Column="3" Click="LiveDrawClearStep3Button_Click" Content="Clear" />
                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Step 4" />
                        <TextBlock x:Name="LiveDrawStep4KeyText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="3" Grid.Column="2" Click="LiveDrawListenStep4Button_Click" Content="Listen" />
                        <Button Grid.Row="3" Grid.Column="3" Click="LiveDrawClearStep4Button_Click" Content="Clear" />
                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Step 5" />
                        <TextBlock x:Name="LiveDrawStep5KeyText" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Text="(not set)" />
                        <Button Grid.Row="4" Grid.Column="2" Click="LiveDrawListenStep5Button_Click" Content="Listen" />
                        <Button Grid.Row="4" Grid.Column="3" Click="LiveDrawClearStep5Button_Click" Content="Clear" />
                    </Grid>
                    <TextBlock
                        x:Name="LiveDrawHotkeyInstructionText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="" />
                    <TextBlock
                        x:Name="LiveDrawHotkeyPreviewText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="" />
                    <TextBlock
                        x:Name="LiveDrawBindingStatusText"
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="" />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <Button
                            x:Name="ApplyLiveDrawHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="ApplyLiveDrawHotkeyButton_Click"
                            Content="Apply Live Draw hotkey" />
                        <Button
                            x:Name="UseDefaultLiveDrawHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="UseDefaultLiveDrawHotkeyButton_Click"
                            Content="Use default" />
                        <Button
                            x:Name="RemoveLiveDrawHotkeyButton"
                            Style="{StaticResource SettingsInlineButtonStyle}"
                            Click="RemoveLiveDrawHotkeyButton_Click"
                            Content="Remove Live Draw hotkey" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Capture mode (frozen overlay) -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Capture Mode" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        TextWrapping="WrapWholeWords"
                        Text="Click without dragging saves the snapped window (or the full virtual screen if nothing snaps); drag to draw a rectangle. Left-click saves, copies to clipboard, and exits capture mode; right-click saves without copying to clipboard and keeps capture mode active."
                        />

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Border Effects" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Control the visual intensity of capture border animations."
                        />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <TextBlock Style="{StaticResource SettingsInlineLabelTextStyle}" Text="Intensity" />
                        <ComboBox
                            x:Name="BorderIntensityComboBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Height="34"
                            IsTextSearchEnabled="False"
                            MinWidth="170"
                            SelectionChanged="BorderIntensityComboBox_SelectionChanged">
                            <ComboBoxItem Content="Subtle" Tag="Subtle" />
                            <ComboBoxItem Content="Balanced" Tag="Balanced" />
                            <ComboBoxItem Content="Bold" Tag="Bold" />
                        </ComboBox>
                    </StackPanel>

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Capture Quality Mode" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Fast is the default for new installs and the fastest. Optimized adds enhancement for text readability. Heavy uses large upscales and heavier filters and can take several seconds on big selections."
                        />
                    <StackPanel Style="{StaticResource SettingsInlineRowStackPanelStyle}">
                        <TextBlock Style="{StaticResource SettingsInlineLabelTextStyle}" Text="Mode" />
                        <ComboBox
                            x:Name="ScreenshotQualityModeComboBox"
                            Style="{StaticResource SettingsInlineControlStyle}"
                            Height="34"
                            IsTextSearchEnabled="False"
                            MinWidth="190"
                            SelectionChanged="ScreenshotQualityModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Fast" Tag="Fast" />
                            <ComboBoxItem Content="Optimized" Tag="Optimized" />
                            <ComboBoxItem Content="Heavy" Tag="Heavy" />
                        </ComboBox>
                    </StackPanel>

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Capture overlay instructions" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Choose whether helper instructions appear in the capture overlay."
                        />
                    <CheckBox
                        x:Name="ShowOverlayInstructionsCheckBox"
                        Style="{StaticResource SettingsInlineControlStyle}"
                        Checked="ShowOverlayInstructionsCheckBox_Changed"
                        Content="Show capture mode overlay instructions"
                        Unchecked="ShowOverlayInstructionsCheckBox_Changed" />
                </StackPanel>
            </Border>

            <!-- App Behavior -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="App Behavior" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Choose whether closing the window keeps Helvety Screen Tools running in the notification area so global hotkeys continue working."
                        />
                    <CheckBox
                        x:Name="MinimizeToTrayOnCloseCheckBox"
                        Style="{StaticResource SettingsInlineControlStyle}"
                        Checked="MinimizeToTrayOnCloseCheckBox_Changed"
                        Content="Keep app running in notification area when window is closed"
                        Unchecked="MinimizeToTrayOnCloseCheckBox_Changed" />

                    <Border
                        Height="1"
                        Margin="0,4,0,4"
                        Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <TextBlock Style="{StaticResource SettingsSubsectionTitleTextStyle}" Text="Editor Performance Mode" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Enabled (recommended): keeps editing interactions smoother by temporarily reducing expensive visual effects while dragging or resizing. Disable only if you need to always preview full shadows/borders during movement."
                        TextWrapping="WrapWholeWords" />
                    <CheckBox
                        x:Name="EditorPerformanceModeCheckBox"
                        Style="{StaticResource SettingsInlineControlStyle}"
                        Checked="EditorPerformanceModeCheckBox_Changed"
                        Content="Enable Editor Performance Mode"
                        Unchecked="EditorPerformanceModeCheckBox_Changed" />
                </StackPanel>
            </Border>

            <!-- Danger Zone -->
            <Border Style="{StaticResource SettingsCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SettingsSectionTitleTextStyle}" Text="Danger Zone" />
                    <TextBlock
                        Style="{StaticResource SettingsSectionDescriptionTextStyle}"
                        Text="Reset all app settings to defaults. This clears saved configuration (save location, capture and Live Draw hotkeys, editor preferences, border effects, capture quality, and related options). Your image files and captures on disk are not deleted."
                        TextWrapping="WrapWholeWords"
                        />
                    <Button
                        x:Name="ResetSettingsButton"
                        Style="{StaticResource SettingsInlineButtonStyle}"
                        Click="ResetSettingsButton_Click"
                        Content="Reset to Defaults" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
