<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="helvety.screentools.Capture.LiveDrawOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Live Draw">
    <Grid
        x:Name="RootGrid"
        UseSystemFocusVisuals="False"
        Background="Transparent"
        KeyDown="RootGrid_KeyDown"
        PointerPressed="RootGrid_PointerPressed"
        PointerMoved="RootGrid_PointerMoved"
        PointerReleased="RootGrid_PointerReleased">
        <Image
            x:Name="BackgroundImage"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Stretch="None"
            IsHitTestVisible="False" />
        <Canvas x:Name="DrawCanvas" Background="Transparent" />
        <Canvas x:Name="PreviewCanvas" IsHitTestVisible="False" />
        <Canvas x:Name="BorderCanvas" IsHitTestVisible="False">
            <Rectangle
                x:Name="SnapBorderRectangle"
                Stroke="#FFD81B60"
                StrokeThickness="4"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderChaseRectangle"
                Stroke="White"
                StrokeDashArray="26,180"
                StrokeThickness="3"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderCornerGlowRectangle"
                Stroke="#66FFFFFF"
                StrokeDashArray="18,68,18,220"
                StrokeThickness="6"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderGlowRectangle"
                Stroke="#44FFFFFF"
                StrokeThickness="8"
                Visibility="Collapsed" />
        </Canvas>
    </Grid>
</Window>
