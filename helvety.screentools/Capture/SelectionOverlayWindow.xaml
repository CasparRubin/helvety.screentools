<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="helvety.screentools.Capture.SelectionOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Capture Selection">
    <Grid
        x:Name="RootGrid"
        UseSystemFocusVisuals="False"
        Background="Transparent"
        KeyDown="RootGrid_KeyDown"
        PointerMoved="RootGrid_PointerMoved"
        PointerPressed="RootGrid_PointerPressed"
        PointerReleased="RootGrid_PointerReleased">
        <Image
            x:Name="BackgroundImage"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Stretch="None" />

        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Line
                x:Name="VerticalCursorGuide"
                Stroke="#8A8A8A"
                StrokeDashArray="2,6"
                StrokeThickness="1" />
            <Line
                x:Name="HorizontalCursorGuide"
                Stroke="#8A8A8A"
                StrokeDashArray="2,6"
                StrokeThickness="1" />
            <Rectangle
                x:Name="DimTop"
                Fill="#B3000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DimLeft"
                Fill="#B3000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DimRight"
                Fill="#B3000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DimBottom"
                Fill="#B3000000"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderRectangle"
                Stroke="#FFD81B60"
                StrokeThickness="4"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderChaseRectangle"
                Stroke="White"
                StrokeDashArray="26,180"
                StrokeThickness="3"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderCornerGlowRectangle"
                Stroke="#66FFFFFF"
                StrokeDashArray="18,68,18,220"
                StrokeThickness="6"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="SnapBorderGlowRectangle"
                Stroke="#44FFFFFF"
                StrokeThickness="8"
                Visibility="Collapsed" />
            <Rectangle
                x:Name="DragRectangle"
                Fill="#33D81B60"
                Stroke="#FFD81B60"
                StrokeThickness="2"
                Visibility="Collapsed" />
            <Border
                x:Name="InstructionPanel"
                MaxWidth="520"
                Padding="16"
                Background="#FA202020"
                BorderBrush="#66262626"
                BorderThickness="1"
                CornerRadius="0">
                <StackPanel Spacing="{StaticResource AppSpacingContent}">
                    <StackPanel Spacing="2">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Capture mode" />
                        <TextBlock
                            Foreground="#FFE6E6E6"
                            Text="Click to capture the snapped window or the full screen; drag to select a rectangle."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Grid RowSpacing="{StaticResource AppSpacingStack}" ColumnSpacing="{StaticResource AppSpacingStack}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Padding="8,3"
                            Background="#FF2A2A2A"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="LMB" />
                        </Border>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="White"
                            TextWrapping="WrapWholeWords">
                            <Run FontWeight="SemiBold" Text="Left click" />
                            <Run Text=" saves the snapped area (or full screen if nothing snaps), copies to clipboard, and exits. Drag for a custom rectangle." />
                        </TextBlock>

                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            Padding="8,3"
                            Background="#FF2A2A2A"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="RMB" />
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="White"
                            TextWrapping="WrapWholeWords">
                            <Run FontWeight="SemiBold" Text="Right click" />
                            <Run Text=" saves the file and stays in capture mode (no clipboard copy)." />
                        </TextBlock>

                        <Border
                            Grid.Row="2"
                            Grid.Column="0"
                            Padding="8,3"
                            Background="#FF2A2A2A"
                            CornerRadius="6">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="ESC" />
                        </Border>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="White"
                            TextWrapping="WrapWholeWords">
                            <Run FontWeight="SemiBold" Text="Esc" />
                            <Run Text=" cancels capture mode." />
                        </TextBlock>
                    </Grid>

                    <Border
                        x:Name="InstructionStatusCard"
                        Padding="10"
                        Background="#E62A2A2A"
                        CornerRadius="0">
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="12"
                                Foreground="#FFDCDCDC"
                                Text="Latest status" />
                            <TextBlock
                                x:Name="InstructionStatusText"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Waiting for selection..."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="8,6"
                        Background="#D92A2A2A"
                        CornerRadius="0">
                        <TextBlock
                            Foreground="#FFDCDCDC"
                            Text="Note: This panel is never included in saved captures."
                            TextWrapping="WrapWholeWords" />
                    </Border>
                </StackPanel>
            </Border>

            <Border
                x:Name="SessionToastCard"
                MaxWidth="520"
                Padding="10"
                Background="#F0262626"
                BorderBrush="#66262626"
                BorderThickness="1"
                CornerRadius="0"
                Visibility="Collapsed">
                <StackPanel Spacing="2">
                    <TextBlock
                        x:Name="SessionToastTitleText"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Capture saved" />
                    <TextBlock
                        x:Name="SessionToastDetailText"
                        Foreground="#FFDCDCDC"
                        Text="Folder path"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
